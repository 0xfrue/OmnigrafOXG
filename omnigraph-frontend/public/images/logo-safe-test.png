t_f.push([1,"9:I[41549,[\"8450\",\"static/chunks/8450-6725cfb79d930aa0.js\",\"7773\",\"static/chunks/7773-db966e78a075eee8.js\",\"5826\",\"static/chunks/5826-064aa311e73887fd.js\",\"7869\",\"static/chunks/7869-c0c2db70640d68e0.js\",\"5158\",\"static/chunks/5158-e0f546033b4db5ad.js\",\"4926\",\"static/chunks/4926-da5e05a7ec4c28a6.js\",\"7735\",\"static/chunks/7735-750a34234d1fa91c.js\",\"4515\",\"static/chunks/4515-3accd1f052e438b8.js\",\"8218\",\"static/chunks/8218-2b6a64b9aeb3049a.js\",\"3392\",\"static/chunks/3392-98aba41b61839aa8.js\",\"1103\",\"static/chunks/1103-83c24964aea4045c.js\",\"7731\",\"static/chunks/7731-0f5ddb85d9bd1c8b.js\",\"4296\",\"static/chunks/4296-a5ecf4fdbd31a0d9.js\",\"5839\",\"static/chunks/5839-6ac009742c4e3466.js\",\"8974\",\"static/chunks/app/page-7e3d430cc9219740.js\"],\"default\"]\n"])</script><script>self.__next_f.push([1,"17:I[37256,[],\"\"]\n:HL[\"/_next/static/css/87f24c45c8e71ae2.css\",\"style\"]\na:Ta3e,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is Safe{Wallet}?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Safe{Wallet} is a self-custody smart contract wallet that enables multisig security, programmable access control, and secure treasury management across multiple blockchains. Unlike single-key wallets or custodial providers, Safe uses onchain smart contracts to remove single points of failure while allowing teams and individuals to define custom signing rules, spending limits, and recovery mechanisms. Safe is used by DAOs, foundations, protocols, and advanced users to secure digital assets without relying on centralized custody or offchain MPC systems.\"}},{\"@type\":\"Question\",\"name\":\"What is a multi-signature wallet?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A multi-signature wallet, or multisig wallet, requires multiple signers to approve a transaction. Instead of relying on a single signature, multisig wallets distribute control across trusted participants to increase security.\"}},{\"@type\":\"Question\",\"name\":\"How does a multi-signature wallet work?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A multisig wallet works by enforcing threshold-based signature rules on the blockchain. Transactions are executed only after the required number of authorised signers approve them.\"}},{\"@type\":\"Question\",\"name\":\"Why use multisig wallets instead of traditional crypto wallets?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Traditional crypto wallets rely on a single private key. Multisig wallets reduce the risk of loss or compromise by distributing control across multiple signers, removing the single point of failure.\"}},{\"@type\":\"Question\",\"name\":\"Can I create a multisig wallet with Safe{Wallet}?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. You can create a multisig wallet with Safe{Wallet} in minutes, invite trusted signers, define approval thresholds, and begin managing digital assets securely.\"}},{\"@type\":\"Question\",\"name\":\"Is a multisig wallet more secure than a hardware wallet?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Hardware wallets protect private keys offline but still rely on a single signer. A multisig wallet distributes risk across multiple participants and can be combined with hardware wallets for stronger security practices.\"}},{\"@type\":\"Question\",\"name\":\"Can multisig wallets be used for Bitcoin?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Multisig wallets originated in the Bitcoin ecosystem and are widely used across blockchain networks. Safe extends multisig security to Ethereum and other supported networks.\"}}]}"])</script><script>self.__next_f.push([1,"0:{\"P\":null,\"b\":\"vCTX_lIQJfITnu-4nOTG9\",\"p\":\"\",\"c\":[\"\",\"\"],\"i\":false,\"f\":[[[\"\",{\"children\":[\"__PAGE__\",{}]},\"$undefined\",\"$undefined\",true],[\"\",[\"$\",\"$1\",\"c\",{\"chil